<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Base.Theme.SplashScreen" parent="@android:style/Theme.DeviceDefault.DayNight">
        <item name="android:windowLayoutInDisplayCutoutMode">1</item>
        <item name="android:enforceStatusBarContrast">false</item>
        <item name="android:enforceNavigationBarContrast">false</item>
        <item name="isLightTheme">?android:attr/isLightTheme</item>
    </style>
    <style name="Base.Theme.SplashScreen.Light" parent="@style/Base.Theme.SplashScreen">
    </style>
    <style name="Glance.AppWidget.TextAppearance.Bold" parent="@style/Glance.AppWidget.TextAppearance.DeviceDefaultFontFamily">
        <item name="android:textFontWeight">700</item>
    </style>
    <style name="Glance.AppWidget.TextAppearance.DeviceDefaultFontFamily" parent="@android:style/TextAppearance.DeviceDefault">
        <item name="android:textSize">@null</item>
        <item name="android:typeface">@null</item>
        <item name="android:textColor">@null</item>
        <item name="android:textColorLink">@null</item>
        <item name="android:shadowColor">@null</item>
        <item name="android:shadowDx">@null</item>
        <item name="android:shadowDy">@null</item>
        <item name="android:shadowRadius">@null</item>
        <item name="android:elegantTextHeight">@null</item>
        <item name="android:letterSpacing">@null</item>
        <item name="android:fontFeatureSettings">@null</item>
        <item name="android:fontVariationSettings">@null</item>
    </style>
    <style name="Glance.AppWidget.Theme" parent="@android:style/Theme.DeviceDefault.DayNight">
    </style>
    <style name="Theme.Claude" parent="@android:style/Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/bg100</item>
        <item name="android:isLightTheme">true</item>
    </style>
    <style name="Theme.Claude.Splash" parent="@style/Theme.SplashScreen">
        <item name="android:isLightTheme">true</item>
        <item name="postSplashScreenTheme">@style/Theme.Claude</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo_claude_splash</item>
        <item name="windowSplashScreenBackground">@color/bg100</item>
    </style>
</resources>
