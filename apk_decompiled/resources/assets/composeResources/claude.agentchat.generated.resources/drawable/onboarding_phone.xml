            android:pathData="M13.86,7.161 H39.36 A9,9 0 0,1 48.36,16.161 V79.161 A9,9 0 0,1 39.36,88.161 H13.86 A9,9 0 0,1 4.86,79.161 V16.161 A9,9 0 0,1 13.86,7.161 Z"/>
