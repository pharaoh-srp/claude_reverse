            android:pathData="M13.86,10.161 H39.36 A6,6 0 0,1 45.36,16.161 V79.161 A6,6 0 0,1 39.36,85.161 H13.86 A6,6 0 0,1 7.86,79.161 V16.161 A6,6 0 0,1 13.86,10.161 Z"
            android:fillColor="#F5F4ED"/>
        <!-- Input bar fill: local (10.86, 77.661) 31.5x4.5 rx=2.25 -->
