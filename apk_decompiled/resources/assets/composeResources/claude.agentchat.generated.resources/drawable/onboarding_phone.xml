            android:pathData="M13.11,77.286 H40.11 A2.625,2.625 0 0,1 42.735,79.911 V79.911 A2.625,2.625 0 0,1 40.11,82.536 H13.11 A2.625,2.625 0 0,1 10.485,79.911 V79.911 A2.625,2.625 0 0,1 13.11,77.286 Z"
            android:strokeColor="#261F1E1D"
            android:strokeWidth="0.75"/>

        <!-- Counter-rotation: these paths already have rotation baked in by Figma -->
        <group
            android:rotation="7"
            android:pivotX="4.86"
            android:pivotY="7.161">
